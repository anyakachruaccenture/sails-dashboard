# Azure App Registration — obtained from Azure Portal > App registrations > your app
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# SharePoint / OneDrive identifiers — see README for how to find these
SHAREPOINT_SITE_ID=your-sharepoint-site-id
DRIVE_ID=your-drive-id
FILE_ID=your-file-id

# Name of the worksheet tab inside the Excel file (default: Sheet1)
SHEET_NAME=Sheet1
